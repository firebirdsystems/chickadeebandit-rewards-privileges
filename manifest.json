{
  "id": "rewards-privileges",
  "name": "Rewards",
  "version": "1.1.0",
  "description": "A lightweight motivation layer for kids: adults define redeemable rewards, kids see what they are working toward, and approved redemptions celebrate effort without making every chore about money.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": [
    "kids",
    "rewards",
    "motivation",
    "chores",
    "allowance"
  ],
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_encryption": "off",
  "row_policies": {
    "rewards": { "kind": "adult_writable" },
    "redemption_requests": {
      "kind": "owner_only",
      "member_column": "member_id",
      "member_can_update": false
    },
    "redemption_decisions": {
      "kind": "adult_writable",
      "member_read_column": "member_id"
    },
    "points_ledger": {
      "kind": "adult_writable",
      "member_read_column": "member_id"
    }
  },
  "publishes": [
    "reward.available",
    "reward.redeemed"
  ],
  "alert_on": [
    "reward.available",
    "reward.redeemed"
  ],
  "subscribes_to": [
    "chore.completed",
    "chore.streak",
    "allowance.earned"
  ],
  "publish_acls": {
    "reward.available": { "require_role": "adult" },
    "reward.redeemed": { "require_role": "adult" }
  },
  "automation_actions": {
    "credit_points": {
      "title": "Award reward points",
      "description": "Add points to a member's durable reward-points balance.",
      "params": {
        "member_id": { "type": "member", "label": "Whose points", "required": true },
        "points": { "type": "integer", "label": "Points", "required": true, "min": 1 }
      },
      "dedupe": { "table": "points_ledger", "column": "event_id" },
      "steps": [
        {
          "op": "insert",
          "table": "points_ledger",
          "on_conflict": "ignore",
          "values": {
            "event_id": "$event_id",
            "member_id": ":member_id",
            "points": ":points",
            "earned_at": "$now"
          }
        }
      ]
    }
  },
  "suggested_automations": [
    {
      "title": "Award points when a chore is completed",
      "description": "Every completed chore adds its point value to the member's reward-points balance. These points persist so kids can save toward bigger rewards.",
      "trigger_event": "chore.completed",
      "target_app_id": "rewards-privileges",
      "action_id": "credit_points",
      "param_map": {
        "member_id": { "kind": "payload_field", "value": "member_id" },
        "points": { "kind": "payload_field", "value": "points" }
      }
    }
  ],
  "exports": [
    "reward-catalog",
    "kid-motivation"
  ],
  "nav": { "label": "Rewards" },
  "widget": {
    "label": "Rewards",
    "size": "small"
  },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "🎁"
}
